# Copy to .env and fill in. All AI keys are OPTIONAL — the app runs without them
# (RAG falls back to TF-IDF, generation falls back to Ollama, then a template).

# JWT signing secret (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# --- LLM providers (priority order: Gemini -> OpenRouter -> Ollama -> template) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Ollama backup (local). Pull a model first, e.g. `ollama pull llama3.2:3b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Embeddings for RAG: "gemini" uses Gemini API, "tfidf" is fully local (default/fallback)
EMBEDDINGS_BACKEND=tfidf
